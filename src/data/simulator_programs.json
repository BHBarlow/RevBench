[
  {
    "id": "function-call",
    "name": "Function Call & Stack Frame",
    "description": "Visualizes how a function sets up a local workspace (stack frame) using the Base Pointer (RBP) and Stack Pointer (RSP).",
    "code": [
      "CALL calculate    ; Push return addr & jump",
      "MOV RBX, RAX      ; Save result",
      "HLT               ; End of program",
      "calculate:",
      "PUSH RBP          ; Save caller's base pointer",
      "MOV RBP, RSP      ; Set new base pointer",
      "SUB RSP, 8        ; Allocate local variables",
      "MOV [RBP-8], 42   ; Write to local var",
      "MOV RAX, [RBP-8]  ; Read from local var",
      "MOV RSP, RBP      ; Deallocate locals",
      "POP RBP           ; Restore caller's base pointer",
      "RET               ; Pop return addr & jump back"
    ],
    "initial_state": {
      "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00008000", "RBP": "0x00008000" },
      "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
      "stack": []
    },
    "steps": [
      {
        "line": 0,
        "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF8", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "CALL calculate: The CPU pushes the 'return address' (the address of the next instruction, 'MOV RBX, RAX') onto the stack so it knows where to go back to after the function is done. RSP decreases by 8."
      },
      {
        "line": 4,
        "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF0", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "PUSH RBP (Prologue): We are now inside the function! First, we save the caller's Base Pointer (RBP) onto the stack. This protects the caller's environment."
      },
      {
        "line": 5,
        "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF0", "RBP": "0x00007FF0" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "MOV RBP, RSP (Prologue): We set the Base Pointer (RBP) to equal the current Stack Pointer (RSP). RBP now acts as a stable 'anchor' point for our new local workspace (the Stack Frame). Notice RBP and RSP are now identical."
      },
      {
        "line": 6,
        "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FE8", "RBP": "0x00007FF0" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FE8", "value": "0x00000000 (Uninitialized)" },
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "SUB RSP, 8: We subtract 8 from RSP to reserve 8 bytes of space on the stack for local variables. RBP stays still, pointing to the start of our frame, while RSP drops down to make room."
      },
      {
        "line": 7,
        "registers": { "RAX": "0x00000000", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FE8", "RBP": "0x00007FF0" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FE8", "value": "0x0000002A (Decimal 42)" },
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "MOV [RBP-8], 42: We write the value 42 (0x2A) into our local variable space. We find this space by calculating 'RBP minus 8'."
      },
      {
        "line": 8,
        "registers": { "RAX": "0x0000002A", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FE8", "RBP": "0x00007FF0" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FE8", "value": "0x0000002A (Decimal 42)" },
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "MOV RAX, [RBP-8]: We read our local variable and put it into RAX. RAX is the standard register used for returning values from a function."
      },
      {
        "line": 9,
        "registers": { "RAX": "0x0000002A", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF0", "RBP": "0x00007FF0" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FE8", "value": "0x0000002A (Garbage)" },
          { "address": "0x00007FF0", "value": "0x00008000 (Old RBP)" },
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "MOV RSP, RBP (Epilogue): We are done! To clean up our local variables, we simply move RSP back up to where RBP is. The local variables (like our 42) are still in memory, but they are now considered 'garbage' below the active stack."
      },
      {
        "line": 10,
        "registers": { "RAX": "0x0000002A", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF8", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF8", "value": "0x0040001A (Ret Addr)" }
        ],
        "explanation": "POP RBP (Epilogue): We pop the old, original Base Pointer off the stack and back into the RBP register. The caller's environment is fully restored!"
      },
      {
        "line": 11,
        "registers": { "RAX": "0x0000002A", "RBX": "0x00000000", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00008000", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [],
        "explanation": "RET: The CPU pops the return address (0x0040001A) off the stack and jumps back to it."
      },
      {
        "line": 1,
        "registers": { "RAX": "0x0000002A", "RBX": "0x0000002A", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00008000", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [],
        "explanation": "MOV RBX, RAX: Back in the caller, we save the result of the function (42) into RBX."
      }
    ]
  },
