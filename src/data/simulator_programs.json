      },
      {
        "line": 1,
        "registers": { "RAX": "0x00001122", "RBX": "0x00003344", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00008000", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [],
        "explanation": "Loads 0x3344 into RBX."
      },
      {
        "line": 2,
        "registers": { "RAX": "0x00001122", "RBX": "0x00003344", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF8", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF8", "value": "0x00001122" }
        ],
        "explanation": "PUSH RAX: The Stack Pointer (RSP) decreases by 8 bytes, and the value of RAX (0x1122) is written to the new top of the stack. Notice how RSP points to the newest item."
      },
      {
        "line": 3,
        "registers": { "RAX": "0x00001122", "RBX": "0x00003344", "RCX": "0x00000000", "RDX": "0x00000000", "RSP": "0x00007FF0", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF0", "value": "0x00003344" },
          { "address": "0x00007FF8", "value": "0x00001122" }
        ],
        "explanation": "PUSH RBX: RSP decreases by 8 again. The value of RBX (0x3344) is placed on top of the stack."
      },
      {
        "line": 4,
        "registers": { "RAX": "0x00001122", "RBX": "0x00003344", "RCX": "0x00003344", "RDX": "0x00000000", "RSP": "0x00007FF8", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF0", "value": "0x00003344 (Popped)" },
          { "address": "0x00007FF8", "value": "0x00001122" }
        ],
        "explanation": "POP RCX: The value at the top of the stack (0x3344) is copied into the RCX register. Then, RSP is incremented by 8. The memory isn't deleted, but it is now 'above' the active stack."
      },
      {
        "line": 5,
        "registers": { "RAX": "0x00001122", "RBX": "0x00003344", "RCX": "0x00003344", "RDX": "0x00001122", "RSP": "0x00008000", "RBP": "0x00008000" },
        "flags": { "ZF": 0, "SF": 0, "OF": 0, "CF": 0 },
        "stack": [
          { "address": "0x00007FF0", "value": "0x00003344 (Popped)" },
          { "address": "0x00007FF8", "value": "0x00001122 (Popped)" }
        ],
        "explanation": "POP RDX: The next value (0x1122) is popped into RDX. RSP is incremented back to its starting value. Values come off the stack in Last-In-First-Out (LIFO) order!"
      }
    ]
